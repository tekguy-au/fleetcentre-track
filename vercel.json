{
  "rewrites": [
    { "source": "/driver", "destination": "/driver.html" },
    { "source": "/track", "destination": "/track.html" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "driver.fleetcentre.com.au" }],
      "destination": "/driver",
      "permanent": false
    },
    { "source": "/", "destination": "/track", "permanent": false }
  ]
}
