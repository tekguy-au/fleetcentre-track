      "id": "poll-response",
      "name": "Poll Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        704,
        528
      ]
    },
    {
      "parameters": {
        "jsCode": "// Simple in-memory store using static data\nconst staticData = $getWorkflowStaticData('global');\n\nconst body = $input.first().json.body;\nconst id = body.id;\n\nif (!staticData.sessions) staticData.sessions = {};\n\nif (body.type === 'create') {\n  const sessionId = Math.random().toString(36).substring(2, 10);\n  staticData.sessions[sessionId] = { lat: null, lng: null, heading: null, speed: null, status: 'preparing', ts: null };\n  return [{ json: { ok: true, id: sessionId } }];\n}\n\nif (body.type === 'location' && id && staticData.sessions[id]) {\n  staticData.sessions[id] = {\n    lat: body.lat,\n    lng: body.lng,\n    heading: body.heading || null,\n    speed: body.speed || null,\n    status: 'active',\n    ts: Date.now()\n  };\n  return [{ json: { ok: true } }];\n}\n\nif (body.type === 'delivered' && id && staticData.sessions[id]) {\n  staticData.sessions[id].status = 'delivered';\n  staticData.sessions[id].ts = Date.now();\n  return [{ json: { ok: true } }];\n}\n\nreturn [{ json: { error: 'invalid request' } }];"
      },
      "id": "process-update",
      "name": "Process Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst id = $input.first().json.query.id;\n\nif (!staticData.sessions || !staticData.sessions[id]) {\n  return [{ json: { error: 'not found' } }];\n}\n\nreturn [{ json: staticData.sessions[id] }];"
      },
