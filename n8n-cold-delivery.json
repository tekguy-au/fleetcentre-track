      "id": "list-trigger",
      "name": "List Sessions",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        260,
        740
      ],
      "webhookId": "cold-list"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst sessions = staticData.sessions || {};\nconst FRESH_MS = 10 * 60 * 1000;\nconst now = Date.now();\n\nconst list = Object.keys(sessions)\n  .filter(id => sessions[id].status !== 'delivered' && sessions[id].lat !== null && sessions[id].ts && (now - sessions[id].ts) < FRESH_MS)\n  .map(id => ({ id, ...sessions[id] }));\n\nreturn [{ json: { sessions: list } }];"
      },
